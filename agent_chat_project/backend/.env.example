# Backend-only secrets. Do not expose these values to the frontend.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
TAVILY_API_KEY=

# Optional. When set, task APIs require this value as either:
# Authorization: Bearer <token> or X-Agent-Chat-Token: <token>.
AGENT_CHAT_ACCESS_TOKEN=

# Optional override. Defaults to ./storage/tasks under this backend directory.
AGENT_CHAT_TASK_ROOT=

# Optional safety limits.
AGENT_CHAT_MAX_UPLOAD_FILES=10
AGENT_CHAT_MAX_UPLOAD_FILE_BYTES=10485760
AGENT_CHAT_MAX_UPLOAD_REQUEST_BYTES=105906176
AGENT_CHAT_MAX_JSON_REQUEST_BYTES=65536
DEEPSEEK_TIMEOUT_SECONDS=15
